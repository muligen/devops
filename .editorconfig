# EditorConfig - https://editorconfig.org
# 适用于所有编辑器和 IDE

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Go 文件
[*.go]
indent_size = 4

# C++ 文件
[*.{cpp,hpp,c,h,cc,hh}]
indent_size = 4

# YAML 文件
[*.{yaml,yml}]
indent_size = 2

# JSON 文件
[*.json]
indent_size = 2

# Markdown 文件
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# SQL 文件
[*.sql]
indent_size = 2

# Shell 脚本
[*.sh]
indent_size = 2

# Makefile (必须使用 Tab)
[Makefile]
indent_style = tab

# CMake 文件
[{CMakeLists.txt,*.cmake}]
indent_size = 2

#配置文件
[{config.yaml,.clang-format}]
indent_size = 2
